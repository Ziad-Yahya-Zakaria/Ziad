/* ========================================
   مهامي - Main Stylesheet
   المطور: زياد يحيى زكريا
   فريق ZIADPWA
======================================== */

/* ========== CSS Variables ========== */
:root {
    /* Colors */
    --primary-color: #6366f1;
    --primary-light: #818cf8;
    --primary-dark: #4f46e5;
    --secondary-color: #ec4899;
    --secondary-light: #f472b6;
    --secondary-dark: #db2777;
    
    /* Status Colors */
    --success-color: #10b981;
    --warning-color: #f59e0b;
    --danger-color: #ef4444;
    --info-color: #06b6d4;
    
    /* Light Theme */
    --bg-color: #f8fafc;
    --bg-secondary: #ffffff;
    --bg-tertiary: #f1f5f9;
    --text-primary: #1e293b;
    --text-secondary: #64748b;
    --text-muted: #94a3b8;
    --border-color: #e2e8f0;
    --shadow-color: rgba(0, 0, 0, 0.1);
    
    /* Spacing */
    --spacing-xs: 4px;
    --spacing-sm: 8px;
    --spacing-md: 16px;
    --spacing-lg: 24px;
    --spacing-xl: 32px;
    
    /* Border Radius */
    --radius-sm: 8px;
    --radius-md: 12px;
    --radius-lg: 16px;
    --radius-xl: 24px;
    --radius-full: 50%;
    
    /* Transitions */
    --transition-fast: 0.15s ease;
    --transition-normal: 0.3s ease;
    --transition-slow: 0.5s ease;
    
    /* Typography */
    --font-family: 'Cairo', sans-serif;
    --font-size-xs: 12px;
    --font-size-sm: 14px;
    --font-size-md: 16px;
    --font-size-lg: 18px;
    --font-size-xl: 24px;
    --font-size-2xl: 32px;
    
    /* Layout */
    --header-height: 60px;
    --sidebar-width: 280px;
    --bottom-nav-height: 70px;
    
    /* Z-Index */
    --z-sidebar: 100;
    --z-overlay: 99;
    --z-header: 98;
    --z-fab: 97;
    --z-bottom-nav: 96;
    --z-modal: 200;
    --z-toast: 300;
    --z-splash: 400;
}

/* ========== Font Size Settings ========== */
body.font-small {
    --font-size-xs: 10px;
    --font-size-sm: 12px;
    --font-size-md: 14px;
    --font-size-lg: 16px;
    --font-size-xl: 20px;
    --font-size-2xl: 28px;
}

body.font-large {
    --font-size-xs: 14px;
    --font-size-sm: 16px;
    --font-size-md: 18px;
    --font-size-lg: 20px;
    --font-size-xl: 28px;
    --font-size-2xl: 36px;
}

/* ========== Reset & Base ========== */
*, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

html {
    font-size: 16px;
    -webkit-tap-highlight-color: transparent;
}

body {
    font-family: var(--font-family);
    font-size: var(--font-size-md);
    line-height: 1.6;
    color: var(--text-primary);
    background-color: var(--bg-color);
    min-height: 100vh;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

body.font-dubai {
    font-family: 'Dubai', sans-serif;
}

body.font-idris {
    font-family: '29LT Idris', sans-serif;
}

a {
    color: var(--primary-color);
    text-decoration: none;
}

button {
    font-family: inherit;
    cursor: pointer;
    border: none;
    background: none;
}

input, textarea, select {
    font-family: inherit;
    font-size: var(--font-size-md);
}

ul, ol {
    list-style: none;
}

img, svg {
    max-width: 100%;
    height: auto;
}

/* ========== Splash Screen ========== */
.splash-screen {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: var(--z-splash);
    transition: opacity var(--transition-slow), visibility var(--transition-slow);
}

.splash-screen.hidden {
    opacity: 0;
    visibility: hidden;
}

.splash-content {
    text-align: center;
    color: white;
}

.splash-icon {
    margin-bottom: var(--spacing-lg);
    animation: pulse 2s infinite;
}

.splash-title {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    margin-bottom: var(--spacing-sm);
}

.splash-subtitle {
    font-size: var(--font-size-md);
    opacity: 0.9;
    margin-bottom: var(--spacing-xl);
}

.splash-loader {
    width: 40px;
    height: 40px;
    border: 3px solid rgba(255,255,255,0.3);
    border-top-color: white;
    border-radius: 50%;
    margin: 0 auto;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

@keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
}

/* ========== App Container ========== */
.app-container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
}

.app-container.hidden {
    display: none;
}

.hidden {
    display: none !important;
}

/* ========== Header ========== */
.app-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--header-height);
    background: var(--bg-secondary);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--spacing-md);
    box-shadow: 0 2px 10px var(--shadow-color);
    z-index: var(--z-header);
}

.header-btn {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-full);
    color: var(--text-primary);
    transition: background var(--transition-fast);
    position: relative;
}

.header-btn:hover {
    background: var(--bg-tertiary);
}

.header-title {
    font-size: var(--font-size-lg);
    font-weight: 600;
    color: var(--text-primary);
}

.notification-badge {
    position: absolute;
    top: 6px;
    right: 6px;
    width: 18px;
    height: 18px;
    background: var(--danger-color);
    color: white;
    font-size: 10px;
    font-weight: 600;
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
}

/* ========== Sidebar ========== */
.sidebar {
    position: fixed;
    top: 0;
    right: -100%;
    width: var(--sidebar-width);
    max-width: 85vw;
    height: 100vh;
    background: var(--bg-secondary);
    box-shadow: -5px 0 20px var(--shadow-color);
    z-index: var(--z-sidebar);
    transition: right var(--transition-normal);
    overflow-y: auto;
}

.sidebar.active {
    right: 0;
}

.sidebar-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: var(--z-overlay);
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--transition-normal), visibility var(--transition-normal);
}

.sidebar-overlay.active {
    opacity: 1;
    visibility: visible;
}

.sidebar-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    padding: var(--spacing-lg);
    border-bottom: 1px solid var(--border-color);
}

.sidebar-logo svg {
    display: block;
}

.sidebar-title {
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--text-primary);
}

.nav-menu {
    padding: var(--spacing-md);
}

.nav-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    padding: var(--spacing-md);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    cursor: pointer;
    transition: all var(--transition-fast);
    margin-bottom: var(--spacing-xs);
}

.nav-item:hover {
    background: var(--bg-tertiary);
    color: var(--text-primary);
}

.nav-item.active {
    background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
    color: white;
}

.nav-item svg {
    flex-shrink: 0;
}

.nav-divider {
    height: 1px;
    background: var(--border-color);
    margin: var(--spacing-md) 0;
}

/* ========== Main Content ========== */
.main-content {
    flex: 1;
    padding: calc(var(--header-height) + var(--spacing-md)) var(--spacing-md) calc(var(--bottom-nav-height) + var(--spacing-xl));
    max-width: 800px;
    margin: 0 auto;
    width: 100%;
}

/* ========== Pages ========== */
.page {
    display: none;
    animation: fadeIn var(--transition-normal);
}

.page.active {
    display: block;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

.page-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-lg);
}

.page-header h2 {
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--text-primary);
}

/* ========== Task Filters ========== */
.task-filters {
    display: flex;
    gap: var(--spacing-sm);
}

.filter-btn {
    padding: var(--spacing-sm) var(--spacing-md);
    border-radius: var(--radius-lg);
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
    background: var(--bg-tertiary);
    transition: all var(--transition-fast);
}

.filter-btn:hover {
    background: var(--border-color);
}

.filter-btn.active {
    background: var(--primary-color);
    color: white;
}

/* ========== Stats Cards ========== */
.tasks-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-lg);
}

.stat-card {
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
    padding: var(--spacing-md);
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    box-shadow: 0 2px 10px var(--shadow-color);
}

.stat-icon {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
}

.stat-icon.pending {
    background: rgba(245, 158, 11, 0.15);
    color: var(--warning-color);
}

.stat-icon.completed {
    background: rgba(16, 185, 129, 0.15);
    color: var(--success-color);
}

.stat-icon.total {
    background: rgba(99, 102, 241, 0.15);
    color: var(--primary-color);
}

.stat-info {
    display: flex;
    flex-direction: column;
}

.stat-value {
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--text-primary);
}

.stat-label {
    font-size: var(--font-size-xs);
    color: var(--text-secondary);
}

/* ========== Tasks List ========== */
.tasks-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
}

.task-item {
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
    padding: var(--spacing-md);
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-md);
    box-shadow: 0 2px 10px var(--shadow-color);
    border-right: 4px solid var(--primary-color);
    cursor: pointer;
    transition: all var(--transition-fast);
}

.task-item:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px var(--shadow-color);
}

.task-item.completed {
    opacity: 0.7;
}

.task-item.completed .task-title {
    text-decoration: line-through;
    color: var(--text-muted);
}

.task-checkbox {
    width: 24px;
    height: 24px;
    border: 2px solid var(--border-color);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    cursor: pointer;
    transition: all var(--transition-fast);
}

.task-checkbox:hover {
    border-color: var(--primary-color);
}

.task-checkbox.checked {
    background: var(--success-color);
    border-color: var(--success-color);
    color: white;
}

.task-content {
    flex: 1;
    min-width: 0;
}

.task-title {
    font-size: var(--font-size-md);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--spacing-xs);
}

.task-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    font-size: var(--font-size-xs);
    color: var(--text-secondary);
}

.task-meta-item {
    display: flex;
    align-items: center;
    gap: 4px;
}

.task-priority {
    padding: 2px 8px;
    border-radius: var(--radius-sm);
    font-size: var(--font-size-xs);
    font-weight: 500;
}

.task-priority.low { background: rgba(16, 185, 129, 0.15); color: var(--success-color); }
.task-priority.medium { background: rgba(245, 158, 11, 0.15); color: var(--warning-color); }
.task-priority.high { background: rgba(239, 68, 68, 0.15); color: var(--danger-color); }
.task-priority.urgent { background: var(--danger-color); color: white; }

/* ========== Empty State ========== */
.empty-state {
    text-align: center;
    padding: var(--spacing-xl) * 2;
    color: var(--text-muted);
}

.empty-state svg {
    margin-bottom: var(--spacing-lg);
    opacity: 0.5;
}

.empty-state h3 {
    font-size: var(--font-size-lg);
    margin-bottom: var(--spacing-sm);
    color: var(--text-secondary);
}

.empty-state p {
    font-size: var(--font-size-sm);
}

/* ========== Achievement Ring ========== */
.achievement-overview {
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    display: flex;
    align-items: center;
    gap: var(--spacing-xl);
    box-shadow: 0 4px 20px var(--shadow-color);
    margin-bottom: var(--spacing-xl);
}

.achievement-ring {
    position: relative;
    width: 120px;
    height: 120px;
    flex-shrink: 0;
}

.achievement-ring svg {
    transform: rotate(-90deg);
}

.ring-bg {
    stroke: var(--bg-tertiary);
}

.ring-progress {
    stroke: var(--primary-color);
    stroke-linecap: round;
    transition: stroke-dashoffset var(--transition-slow);
}

.achievement-percent {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--text-primary);
}

.achievement-details h3 {
    font-size: var(--font-size-lg);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--spacing-sm);
}

.achievement-details p {
    color: var(--text-secondary);
    font-size: var(--font-size-sm);
}

/* ========== Badges ========== */
.achievement-badges h3 {
    font-size: var(--font-size-lg);
    font-weight: 600;
    margin-bottom: var(--spacing-md);
}

.badges-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    gap: var(--spacing-md);
}

.badge-item {
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
    padding: var(--spacing-md);
    text-align: center;
    box-shadow: 0 2px 10px var(--shadow-color);
    transition: transform var(--transition-fast);
}

.badge-item:hover {
    transform: translateY(-3px);
}

.badge-item.locked {
    opacity: 0.5;
    filter: grayscale(1);
}

.badge-icon {
    width: 48px;
    height: 48px;
    margin: 0 auto var(--spacing-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
    border-radius: var(--radius-full);
    color: white;
}

.badge-name {
    font-size: var(--font-size-xs);
    font-weight: 600;
    color: var(--text-primary);
}

/* ========== Forms ========== */
.task-form, .multi-tasks-form {
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    box-shadow: 0 4px 20px var(--shadow-color);
}

.form-group {
    margin-bottom: var(--spacing-lg);
}

.form-group label {
    display: block;
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--spacing-sm);
}

.form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-md);
}

input[type="text"],
input[type="date"],
input[type="time"],
input[type="file"],
textarea,
select {
    width: 100%;
    padding: var(--spacing-md);
    background: var(--bg-tertiary);
    border: 2px solid transparent;
    border-radius: var(--radius-md);
    color: var(--text-primary);
    transition: border-color var(--transition-fast);
}

input:focus,
textarea:focus,
select:focus {
    outline: none;
    border-color: var(--primary-color);
    background: var(--bg-secondary);
}

textarea {
    resize: vertical;
    min-height: 100px;
}

/* ========== Color Picker ========== */
.color-picker {
    display: flex;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
}

.color-option {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    border: 3px solid transparent;
    cursor: pointer;
    transition: all var(--transition-fast);
}

.color-option:hover {
    transform: scale(1.1);
}

.color-option.active {
    border-color: var(--text-primary);
    box-shadow: 0 0 0 2px var(--bg-secondary);
}

/* ========== Buttons ========== */
.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-md) var(--spacing-lg);
    border-radius: var(--radius-md);
    font-size: var(--font-size-md);
    font-weight: 600;
    transition: all var(--transition-fast);
}

.btn-primary {
    background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
    color: white;
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(99, 102, 241, 0.4);
}

.btn-outline {
    background: transparent;
    border: 2px solid var(--primary-color);
    color: var(--primary-color);
}

.btn-outline:hover {
    background: var(--primary-color);
    color: white;
}

.btn-danger {
    background: var(--danger-color);
    color: white;
}

.btn-danger:hover {
    background: #dc2626;
}

.btn-block {
    width: 100%;
}

.btn-sm {
    padding: var(--spacing-sm) var(--spacing-md);
    font-size: var(--font-size-sm);
}

/* ========== KPI Board ========== */
.kpi-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
}

.kpi-card {
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
    box-shadow: 0 2px 10px var(--shadow-color);
}

.kpi-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--spacing-md);
}

.kpi-title {
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
}

.kpi-value {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--spacing-sm);
}

.kpi-change {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    font-size: var(--font-size-sm);
    font-weight: 500;
}

.kpi-change.positive {
    color: var(--success-color);
}

.kpi-change.negative {
    color: var(--danger-color);
}

.kpi-subtitle {
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
}

.kpi-progress {
    height: 8px;
    background: var(--bg-tertiary);
    border-radius: var(--radius-sm);
    overflow: hidden;
}

.kpi-progress-bar {
    height: 100%;
    background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
    border-radius: var(--radius-sm);
    transition: width var(--transition-normal);
}

/* ========== Weekly Chart ========== */
.kpi-chart-section {
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    box-shadow: 0 4px 20px var(--shadow-color);
}

.kpi-chart-section h3 {
    font-size: var(--font-size-lg);
    font-weight: 600;
    margin-bottom: var(--spacing-lg);
}

.weekly-chart {
    height: 200px;
}

.chart-bars {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    height: 150px;
    padding-bottom: var(--spacing-md);
    border-bottom: 2px solid var(--border-color);
}

.chart-bar {
    flex: 1;
    max-width: 40px;
    margin: 0 auto;
    background: linear-gradient(180deg, var(--primary-color), var(--primary-light));
    border-radius: var(--radius-sm) var(--radius-sm) 0 0;
    min-height: 4px;
    transition: height var(--transition-normal);
}

.chart-labels {
    display: flex;
    justify-content: space-between;
    padding-top: var(--spacing-sm);
    font-size: var(--font-size-xs);
    color: var(--text-secondary);
}

/* ========== Notes ========== */
.notes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: var(--spacing-md);
}

.note-card {
    background: #fef3c7;
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
    cursor: pointer;
    transition: all var(--transition-fast);
    position: relative;
}

.note-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 4px 15px var(--shadow-color);
}

.note-title {
    font-size: var(--font-size-md);
    font-weight: 600;
    color: #78350f;
    margin-bottom: var(--spacing-sm);
}

.note-content {
    font-size: var(--font-size-sm);
    color: #92400e;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
}

.note-date {
    font-size: var(--font-size-xs);
    color: #b45309;
    margin-top: var(--spacing-md);
}

.note-delete {
    position: absolute;
    top: var(--spacing-sm);
    left: var(--spacing-sm);
    width: 28px;
    height: 28px;
    border-radius: var(--radius-full);
    background: rgba(0,0,0,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--transition-fast);
}

.note-card:hover .note-delete {
    opacity: 1;
}

/* ========== Reports ========== */
.reports-options {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-md);
}

.report-card {
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    text-align: center;
    cursor: pointer;
    box-shadow: 0 2px 10px var(--shadow-color);
    transition: all var(--transition-fast);
}

.report-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 4px 15px var(--shadow-color);
}

.report-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto var(--spacing-md);
    background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
}

.report-card h3 {
    font-size: var(--font-size-md);
    font-weight: 600;
    margin-bottom: var(--spacing-xs);
}

.report-card p {
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
}

.report-preview {
    margin-top: var(--spacing-xl);
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    box-shadow: 0 4px 20px var(--shadow-color);
}

.report-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--spacing-lg);
    padding-bottom: var(--spacing-md);
    border-bottom: 1px solid var(--border-color);
}

.report-actions {
    display: flex;
    gap: var(--spacing-sm);
}

.report-content {
    font-size: var(--font-size-sm);
    line-height: 1.8;
}

/* ========== Import ========== */
.import-options {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-lg);
}

.import-card {
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    text-align: center;
    box-shadow: 0 4px 20px var(--shadow-color);
}

.import-icon {
    color: var(--primary-color);
    margin-bottom: var(--spacing-lg);
}

.import-card h3 {
    font-size: var(--font-size-lg);
    font-weight: 600;
    margin-bottom: var(--spacing-sm);
}

.import-card p {
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
    margin-bottom: var(--spacing-lg);
}

.import-preview {
    margin-top: var(--spacing-xl);
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    box-shadow: 0 4px 20px var(--shadow-color);
}

.import-list {
    max-height: 300px;
    overflow-y: auto;
    margin-bottom: var(--spacing-lg);
}

.import-actions {
    display: flex;
    gap: var(--spacing-md);
}

/* ========== Notifications ========== */
.notifications-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
}

.notification-item {
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
    padding: var(--spacing-md);
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-md);
    box-shadow: 0 2px 10px var(--shadow-color);
}

.notification-icon {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}

.notification-icon.info { background: rgba(6, 182, 212, 0.15); color: var(--info-color); }
.notification-icon.success { background: rgba(16, 185, 129, 0.15); color: var(--success-color); }
.notification-icon.warning { background: rgba(245, 158, 11, 0.15); color: var(--warning-color); }
.notification-icon.danger { background: rgba(239, 68, 68, 0.15); color: var(--danger-color); }

.notification-content {
    flex: 1;
}

.notification-title {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--spacing-xs);
}

.notification-text {
    font-size: var(--font-size-xs);
    color: var(--text-secondary);
}

.notification-time {
    font-size: var(--font-size-xs);
    color: var(--text-muted);
    margin-top: var(--spacing-sm);
}

/* ========== Task Achievements ========== */
.achievements-summary {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
}

.summary-card {
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    text-align: center;
    box-shadow: 0 2px 10px var(--shadow-color);
}

.summary-value {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    color: var(--primary-color);
}

.summary-label {
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
    margin-top: var(--spacing-sm);
}

.achievements-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
}

.achievement-item {
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
    padding: var(--spacing-md);
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    box-shadow: 0 2px 10px var(--shadow-color);
}

.achievement-icon-wrapper {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-full);
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
}

.achievement-info {
    flex: 1;
}

.achievement-name {
    font-size: var(--font-size-md);
    font-weight: 600;
    color: var(--text-primary);
}

.achievement-desc {
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
}

/* ========== Share Section ========== */
.share-section {
    margin-top: var(--spacing-xl);
    padding: var(--spacing-xl);
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    text-align: center;
    box-shadow: 0 4px 20px var(--shadow-color);
}

.share-section h3 {
    font-size: var(--font-size-lg);
    margin-bottom: var(--spacing-lg);
}

.share-buttons {
    display: flex;
    justify-content: center;
    gap: var(--spacing-md);
}

.share-btn {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transition: all var(--transition-fast);
}

.share-btn:hover {
    transform: translateY(-3px);
}

.share-btn.whatsapp { background: #25D366; }
.share-btn.twitter { background: #000000; }
.share-btn.facebook { background: #1877F2; }
.share-btn.telegram { background: #0088cc; }

/* ========== Settings ========== */
.settings-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
}

.settings-group {
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    padding: var(--spacing-lg);
    box-shadow: 0 4px 20px var(--shadow-color);
}

.settings-group h3 {
    font-size: var(--font-size-md);
    font-weight: 600;
    margin-bottom: var(--spacing-lg);
    padding-bottom: var(--spacing-md);
    border-bottom: 1px solid var(--border-color);
}

.setting-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-md) 0;
    border-bottom: 1px solid var(--border-color);
}

.setting-item:last-child {
    border-bottom: none;
}

.setting-item.clickable {
    cursor: pointer;
    padding: var(--spacing-md);
    margin: 0 calc(var(--spacing-md) * -1);
    border-radius: var(--radius-md);
}

.setting-item.clickable:hover {
    background: var(--bg-tertiary);
}

.setting-info {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
}

.setting-label {
    font-size: var(--font-size-md);
    font-weight: 500;
    color: var(--text-primary);
}

.setting-desc {
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
}

.setting-select {
    padding: var(--spacing-sm) var(--spacing-md);
    background: var(--bg-tertiary);
    border: none;
    border-radius: var(--radius-md);
    color: var(--text-primary);
}

/* ========== Switch ========== */
.switch {
    position: relative;
    display: inline-block;
    width: 52px;
    height: 28px;
}

.switch input {
    opacity: 0;
    width: 0;
    height: 0;
}

.slider {
    position: absolute;
    cursor: pointer;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: var(--border-color);
    transition: var(--transition-fast);
    border-radius: 28px;
}

.slider:before {
    position: absolute;
    content: "";
    height: 22px;
    width: 22px;
    right: 3px;
    bottom: 3px;
    background-color: white;
    transition: var(--transition-fast);
    border-radius: 50%;
}

input:checked + .slider {
    background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
}

input:checked + .slider:before {
    transform: translateX(-24px);
}

/* ========== Theme Colors ========== */
.theme-colors {
    display: flex;
    gap: var(--spacing-sm);
}

.theme-color {
    width: 32px;
    height: 32px;
    border-radius: var(--radius-full);
    border: 3px solid transparent;
    cursor: pointer;
    transition: all var(--transition-fast);
}

.theme-color:hover {
    transform: scale(1.1);
}

.theme-color.active {
    border-color: var(--text-primary);
    box-shadow: 0 0 0 2px var(--bg-secondary);
}

/* ========== Backup ========== */
.backup-options {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
}

.backup-card {
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    text-align: center;
    box-shadow: 0 4px 20px var(--shadow-color);
}

.backup-icon {
    color: var(--primary-color);
    margin-bottom: var(--spacing-lg);
}

.backup-card h3 {
    font-size: var(--font-size-lg);
    font-weight: 600;
    margin-bottom: var(--spacing-sm);
}

.backup-card p {
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
    margin-bottom: var(--spacing-lg);
}

.backup-info {
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
    box-shadow: 0 2px 10px var(--shadow-color);
}

.backup-info h4 {
    font-size: var(--font-size-md);
    font-weight: 600;
    margin-bottom: var(--spacing-sm);
}

.backup-info p {
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
}

/* ========== About ========== */
.about-content {
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    text-align: center;
    box-shadow: 0 4px 20px var(--shadow-color);
}

.about-logo {
    margin-bottom: var(--spacing-lg);
}

.about-title {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--spacing-sm);
}

.about-version {
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
    margin-bottom: var(--spacing-lg);
}

.about-desc {
    font-size: var(--font-size-md);
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: var(--spacing-xl);
    max-width: 400px;
    margin-left: auto;
    margin-right: auto;
}

.about-developer {
    margin-bottom: var(--spacing-xl);
}

.about-developer h3, .about-team h3 {
    font-size: var(--font-size-md);
    font-weight: 600;
    margin-bottom: var(--spacing-md);
    color: var(--text-secondary);
}

.developer-card {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-md);
    padding: var(--spacing-lg);
    background: var(--bg-tertiary);
    border-radius: var(--radius-lg);
}

.developer-avatar {
    width: 56px;
    height: 56px;
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
}

.developer-info h4 {
    font-size: var(--font-size-md);
    font-weight: 600;
    color: var(--text-primary);
}

.developer-info p {
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
}

.about-team {
    margin-bottom: var(--spacing-xl);
}

.team-badge {
    display: inline-block;
    padding: var(--spacing-sm) var(--spacing-lg);
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
    border-radius: var(--radius-lg);
    color: white;
    font-weight: 700;
    font-size: var(--font-size-lg);
}

.about-links {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
}

.about-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-md);
    background: var(--bg-tertiary);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    transition: background var(--transition-fast);
}

.about-link:hover {
    background: var(--border-color);
}

/* ========== Licenses ========== */
.licenses-content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
}

.license-item {
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
    padding: var(--spacing-lg);
    box-shadow: 0 2px 10px var(--shadow-color);
}

.license-item h3 {
    font-size: var(--font-size-md);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--spacing-xs);
}

.license-author {
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
    margin-bottom: var(--spacing-sm);
}

.license-type {
    font-size: var(--font-size-xs);
    color: var(--primary-color);
    font-weight: 500;
}

/* ========== Disclaimer ========== */
.disclaimer-content {
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    padding: var(--spacing-xl);
    box-shadow: 0 4px 20px var(--shadow-color);
}

.disclaimer-section {
    margin-bottom: var(--spacing-xl);
}

.disclaimer-section:last-child {
    margin-bottom: 0;
}

.disclaimer-section h3 {
    font-size: var(--font-size-md);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--spacing-sm);
}

.disclaimer-section p {
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
    line-height: 1.8;
}

/* ========== FAB ========== */
.fab {
    position: fixed;
    bottom: calc(var(--bottom-nav-height) + var(--spacing-lg));
    left: var(--spacing-lg);
    width: 56px;
    height: 56px;
    border-radius: var(--radius-full);
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(99, 102, 241, 0.4);
    z-index: var(--z-fab);
    transition: all var(--transition-fast);
}

.fab:hover {
    transform: scale(1.1);
}

.fab:active {
    transform: scale(0.95);
}

/* ========== Bottom Navigation ========== */
.bottom-nav {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: var(--bottom-nav-height);
    background: var(--bg-secondary);
    display: flex;
    justify-content: space-around;
    align-items: center;
    box-shadow: 0 -2px 10px var(--shadow-color);
    z-index: var(--z-bottom-nav);
    padding-bottom: env(safe-area-inset-bottom);
}

.bottom-nav-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: var(--spacing-sm);
    color: var(--text-muted);
    transition: all var(--transition-fast);
}

.bottom-nav-item span {
    font-size: 10px;
    font-weight: 500;
}

.bottom-nav-item.active {
    color: var(--primary-color);
}

.bottom-nav-item.active svg {
    transform: scale(1.1);
}

/* ========== Modals ========== */
.modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: var(--z-modal);
    opacity: 0;
    visibility: hidden;
    transition: all var(--transition-normal);
    padding: var(--spacing-md);
}

.modal.active {
    opacity: 1;
    visibility: visible;
}

.modal-content {
    background: var(--bg-secondary);
    border-radius: var(--radius-xl);
    width: 100%;
    max-width: 500px;
    max-height: 90vh;
    overflow-y: auto;
    padding: var(--spacing-xl);
    transform: translateY(20px);
    transition: transform var(--transition-normal);
}

.modal.active .modal-content {
    transform: translateY(0);
}

.modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--spacing-lg);
    padding-bottom: var(--spacing-md);
    border-bottom: 1px solid var(--border-color);
}

.modal-header h3 {
    font-size: var(--font-size-lg);
    font-weight: 600;
}

.modal-close {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-secondary);
    transition: all var(--transition-fast);
}

.modal-close:hover {
    background: var(--bg-tertiary);
    color: var(--text-primary);
}

/* ========== Confirm Dialog ========== */
.confirm-content {
    text-align: center;
    max-width: 350px;
}

.confirm-icon {
    color: var(--warning-color);
    margin-bottom: var(--spacing-lg);
}

.confirm-content h3 {
    font-size: var(--font-size-xl);
    margin-bottom: var(--spacing-sm);
}

.confirm-content p {
    color: var(--text-secondary);
    margin-bottom: var(--spacing-xl);
}

.confirm-actions {
    display: flex;
    gap: var(--spacing-md);
}

.confirm-actions .btn {
    flex: 1;
}

/* ========== Task Detail ========== */
.task-detail-content {
    margin-bottom: var(--spacing-lg);
}

.task-detail-title {
    font-size: var(--font-size-xl);
    font-weight: 600;
    margin-bottom: var(--spacing-md);
}

.task-detail-desc {
    color: var(--text-secondary);
    margin-bottom: var(--spacing-lg);
    line-height: 1.8;
}

.task-detail-meta {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-md);
}

.task-detail-item {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
}

.task-detail-item label {
    font-size: var(--font-size-xs);
    color: var(--text-secondary);
}

.task-detail-item span {
    font-size: var(--font-size-sm);
    font-weight: 500;
    color: var(--text-primary);
}

.task-modal-actions {
    display: flex;
    gap: var(--spacing-md);
    padding-top: var(--spacing-lg);
    border-top: 1px solid var(--border-color);
}

.task-modal-actions .btn {
    flex: 1;
}

/* ========== Toast ========== */
.toast {
    position: fixed;
    bottom: calc(var(--bottom-nav-height) + var(--spacing-xl));
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    background: var(--text-primary);
    color: var(--bg-secondary);
    padding: var(--spacing-md) var(--spacing-xl);
    border-radius: var(--radius-lg);
    box-shadow: 0 4px 20px var(--shadow-color);
    z-index: var(--z-toast);
    opacity: 0;
    visibility: hidden;
    transition: all var(--transition-normal);
}

.toast.active {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
}

.toast-content {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
}

.toast-icon svg {
    width: 20px;
    height: 20px;
}

.toast.success .toast-icon { color: var(--success-color); }
.toast.error .toast-icon { color: var(--danger-color); }
.toast.warning .toast-icon { color: var(--warning-color); }
.toast.info .toast-icon { color: var(--info-color); }

/* ========== Log Filters ========== */
.log-filters {
    display: flex;
    gap: var(--spacing-sm);
}

.log-date-input {
    padding: var(--spacing-sm) var(--spacing-md);
    background: var(--bg-tertiary);
    border: none;
    border-radius: var(--radius-md);
    color: var(--text-primary);
}

/* ========== Task Log List ========== */
.task-log-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
}

.log-item {
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
    padding: var(--spacing-md);
    box-shadow: 0 2px 10px var(--shadow-color);
}

.log-date {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--primary-color);
    margin-bottom: var(--spacing-sm);
}

.log-tasks {
    font-size: var(--font-size-sm);
    color: var(--text-secondary);
}

/* ========== Responsive ========== */
@media (min-width: 768px) {
    .main-content {
        padding-bottom: var(--spacing-xl);
    }
    
    .bottom-nav {
        display: none;
    }
    
    .fab {
        bottom: var(--spacing-xl);
    }
    
    .sidebar {
        position: fixed;
        right: 0;
        transform: translateX(100%);
    }
    
    .sidebar.active {
        transform: translateX(0);
    }
}

@media (max-width: 600px) {
    .tasks-stats {
        grid-template-columns: 1fr;
    }
    
    .form-row {
        grid-template-columns: 1fr;
    }
    
    .kpi-grid {
        grid-template-columns: 1fr;
    }
    
    .reports-options {
        grid-template-columns: 1fr;
    }
    
    .import-options {
        grid-template-columns: 1fr;
    }
    
    .backup-options {
        grid-template-columns: 1fr;
    }
    
    .stat-card {
        padding: var(--spacing-sm);
    }
    
    .stat-icon {
        width: 40px;
        height: 40px;
    }
    
    .stat-value {
        font-size: var(--font-size-lg);
    }
    
    .achievement-overview {
        flex-direction: column;
        text-align: center;
    }
}

/* ========== Print Styles ========== */
@media print {
    .app-header,
    .sidebar,
    .bottom-nav,
    .fab,
    .sidebar-overlay {
        display: none !important;
    }
    
    .main-content {
        padding: 0;
    }
    
    .page {
        break-inside: avoid;
    }
}
